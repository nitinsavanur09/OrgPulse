{
  "name": "orgpulse",
  "version": "1.0.0",
  "description": "Salesforce org health and Agentforce AI readiness assessment platform",
  "main": "dist/auth/server.js",
  "scripts": {
    "dev":       "tsx watch src/auth/server.ts",
    "build":     "tsc",
    "start":     "node dist/auth/server.js",
    "scan":      "tsx scripts/run-scan.ts",
    "test-conn":   "tsx scripts/test-connection.ts",
    "test-report":    "tsx scripts/test-report.ts",
    "rebuild-report": "tsx scripts/rebuild-report.ts",
    "lint":           "tsc --noEmit",
    "generate-demo":  "tsx scripts/generate-demo-csv.ts"
  },
  "dependencies": {
    "jsforce":               "^3.0.0",
    "@supabase/supabase-js": "^2.0.0",
    "@anthropic-ai/sdk":     "^0.24.0",
    "express":               "^4.18.0",
    "dotenv":                "^16.0.0"
  },
  "devDependencies": {
    "typescript":     "^5.0.0",
    "tsx":            "^4.0.0",
    "@types/express": "^4.17.0",
    "@types/node":    "^20.0.0"
  }
}
